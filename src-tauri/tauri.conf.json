{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "100 Gun Ormanda",
  "version": "1.0.0",
  "identifier": "com.servankrall.yuzgunormanda",
  "build": {
    "frontendDist": "../www",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "100 Gün Ormanda",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
